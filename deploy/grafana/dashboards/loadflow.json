{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "🔑 Routing Weights (per stream × pool)",
      "description": "核心面板：观察 pressure_rebalance 过程中权重的阶梯式变化",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "loadflow_router_weight",
          "legendFormat": "{{stream}} → {{pool}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "📊 Queue Depth (per pool)",
      "description": "三条线：看谁在堆积、何时开始下降",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "loadflow_pool_pool_queue_depth",
          "legendFormat": "{{pool}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "⚡ Processing Rate (per pool)",
      "description": "各 pool 的实际吞吐，重均衡后慢 pool 的 rate 应该下降",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(loadflow_pool_pool_processed_total[30s])",
          "legendFormat": "{{pool}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "🔄 Rebalance Events",
      "description": "applied/rejected/failed 的计数，标注在时间轴上",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "bars" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(loadflow_rebalance_plan_total[30s])",
          "legendFormat": "{{stream}} - {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "🔗 Sticky Violations (Stream 2)",
      "description": "Stream 2 的粘性违反次数，在 rebalance 时刻出现跳变",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 20, "drawStyle": "bars" },
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(loadflow_routing_violations_total[30s])",
          "legendFormat": "{{stream}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "📦 Orders State Machine (Stream 3)",
      "description": "订单创建/完成/失败计数",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Created" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Completed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        { "expr": "loadflow_orders_created_total", "legendFormat": "Created", "refId": "A" },
        { "expr": "loadflow_orders_completed_total", "legendFormat": "Completed", "refId": "B" },
        { "expr": "loadflow_orders_failed_total", "legendFormat": "Failed", "refId": "C" }
      ]
    },
    {
      "title": "⏱ MySQL Write Latency (p50/p95/p99)",
      "description": "数据库写入延迟分布",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(loadflow_db_write_duration_seconds_bucket[30s]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(loadflow_db_write_duration_seconds_bucket[30s]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(loadflow_db_write_duration_seconds_bucket[30s]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "📈 Stream Throughput (messages/s)",
      "description": "每条 stream 的消息发射速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(loadflow_stream_messages_in_total[30s])",
          "legendFormat": "{{stream}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "🎯 Routing Distribution (per stream → pool)",
      "description": "每条 stream 路由到各 pool 的消息速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(loadflow_router_routed_total[30s])",
          "legendFormat": "{{stream}} → {{pool}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["loadflow", "demo", "retail"],
  "templating": { "list": [] },
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "LoadFlow Retail Demo",
  "uid": "loadflow-retail-demo",
  "version": 1
}
